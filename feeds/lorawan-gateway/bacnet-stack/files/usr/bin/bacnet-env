#!/bin/sh
# Helper: source BACnet UCI config as environment variables,
# then exec the given command.  Used by LuCI tools page.

device=$(uci -q get bacnet.mstp.device)
export BACNET_MSTP_IFACE="/dev/${device:-RS485-1}"
export BACNET_MSTP_BAUD="$(uci -q get bacnet.mstp.baudrate || echo 38400)"
export BACNET_MSTP_MAC="$(uci -q get bacnet.mstp.mac_address || echo 1)"
export BACNET_MAX_MASTER="$(uci -q get bacnet.mstp.max_master || echo 127)"
export BACNET_MAX_INFO_FRAMES="$(uci -q get bacnet.mstp.max_info_frames || echo 1)"
export BACNET_DEVICE_INSTANCE="$(uci -q get bacnet.device.device_instance || echo 1234)"

exec "$@"
