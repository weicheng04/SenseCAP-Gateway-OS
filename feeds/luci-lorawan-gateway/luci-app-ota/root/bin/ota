#!/bin/sh
# Simplified OTA script - direct download from fixed URL

if [ -f /lib/upgrade/ota.sh ]; then
    . /lib/upgrade/ota.sh
    export_ota_url
fi

if [ -z "$OTA_URL_BASE" ]; then
    echo "Unsupported device." >&2
    exit 255
fi

WRLOCK=/var/lock/ota_background.lock
STLOCK=/var/lock/ota_status.lock

action=${1}
shift

download() {
    local url="$1"
    exec 300>$STLOCK
    flock 300
    touch /tmp/firmware.img.tar.gz.part
    echo >/tmp/firmware.img.tar.gz.progress
    flock -u 300
    
    local pid
    echo "Downloading from $url" > /tmp/firmware.img.tar.gz.progress
    flock 300
    echo "#=#=#" >>/tmp/firmware.img.tar.gz.progress
    curl -L --fail --show-error --connect-timeout 5 --progress-bar -o /tmp/firmware.img.tar.gz.part "$url" 2>>/tmp/firmware.img.tar.gz.progress &
    pid="$!"
    echo "$pid" > /var/run/ota/download.pid
    flock -u 300
    
    if wait $pid; then
        rm -f /var/run/ota/download.pid
        echo "Download completed" > /tmp/firmware.img.tar.gz.progress
        flock 300
        mv /tmp/firmware.img.tar.gz.part /tmp/firmware.img.tar.gz
        rm -f /tmp/firmware.img.tar.gz.progress
        flock -u 300
        return 0
    else
        local ecode=$?
        echo >>/tmp/firmware.img.tar.gz.progress
        if [ $ecode -eq 143 ]; then
            echo "Canceled!" >> /tmp/firmware.img.tar.gz.progress
        else
            echo "Download failed!" >> /tmp/firmware.img.tar.gz.progress
        fi
        flock 300
        sed -i '/\r/d' /tmp/firmware.img.tar.gz.progress
        flock -u 300
    fi
    rm -f /var/run/ota/download.pid
    rm -f /tmp/firmware.img.tar.gz.part
    return 1
}

lock_download() {
    local lock="$WRLOCK"
    exec 200>$lock
    flock -n 200 || return
    local url="${1:-$OTA_URL_BASE}"
    download "$url"
    flock -u 200
}

do_check() {
    local ret=0
    local lock="$WRLOCK"
    
    # Force cleanup
    if [ -f /var/run/ota/download.pid ]; then
        local old_pid=$(cat /var/run/ota/download.pid)
        if kill -0 "$old_pid" 2>/dev/null; then
            kill "$old_pid" 2>/dev/null
            sleep 1
            kill -9 "$old_pid" 2>/dev/null
        fi
        rm -f /var/run/ota/download.pid
        rm -f /tmp/firmware.img.tar.gz.part
        rm -f /tmp/firmware.img.tar.gz.progress
    fi
    
    exec 200>$lock
    if flock -n 200; then
        mkdir -p /var/run/ota
        
        # Version check
        local firmware_url="${1:-$OTA_URL_BASE}"
        local version_url="$(dirname "$firmware_url")/version.txt"
        
        # Get remote version (last field of first line)
        local remote_version=$(curl -L --fail --silent --connect-timeout 10 --max-time 30 "$version_url" 2>/dev/null | head -1 | awk '{print $NF}' | tr -d '[:space:]')
        
        if [ -z "$remote_version" ]; then
            echo "Unable to retrieve firmware version from the provided URL." >&2
            flock -u 200 >/dev/null 2>&1
            return 1
        fi
        
        # Get local version (last field of first line)
        if [ -f /version.txt ]; then
            local local_version=$(head -1 /version.txt | awk '{print $NF}' | tr -d '[:space:]')
            if [ "$local_version" = "$remote_version" ]; then
                echo "Current version is already the selected version." >&2
                flock -u 200 >/dev/null 2>&1
                return 3
            fi
        fi
        
        echo "Ready to download firmware from:" > /var/run/ota/ota.log
        echo "$firmware_url" >> /var/run/ota/ota.log
        ret=0
        flock -u 200 >/dev/null 2>&1
        elif [ -f /tmp/firmware.img.tar.gz.progress -o -f /tmp/firmware.img.tar.gz ]; then
        ret=2
    else
        echo "lock failed" >&2
        ret=254
    fi
    
    return $ret
}

do_download() {
    lock_download "$@" &
    return 0
}

do_progress() {
    [ -f /tmp/firmware.img.tar.gz ] && [ ! -f /tmp/firmware.img.tar.gz.progress ] && return 0
    [ -f /tmp/firmware.img.tar.gz.progress ] || { echo "download not in progress" >&2 ; return 254; }
    
    if [ -f /tmp/firmware.img.tar.gz.part ]; then
        # Extract percentage from curl progress bar
        local progress=$(cat /tmp/firmware.img.tar.gz.progress | tr '\r' '\n' | tail -n1 | grep -o '[0-9]\+\.[0-9]\+%' | tail -1)
        if [ -n "$progress" ]; then
            echo "$progress"
            return 1
        else
            echo "0%"
            return 1
        fi
    fi
    
    if ! [ -f /tmp/firmware.img.tar.gz ]; then
        cat /tmp/firmware.img.tar.gz.progress >&2
        return 2
    fi
    
    return 0
}

do_cancel() {
    if [ -f /var/run/ota/download.pid ]; then
        local pid=$(cat /var/run/ota/download.pid)
        if kill -0 "$pid" 2>/dev/null; then
            kill "$pid" 2>/dev/null
            sleep 1
            kill -9 "$pid" 2>/dev/null
        fi
        rm -f /var/run/ota/download.pid
    fi
    
    rm -f /tmp/firmware.img.tar.gz.part
    rm -f /tmp/firmware.img.tar.gz
    rm -f /tmp/firmware.img.tar.gz.progress
    
    return 0
}

do_upgrade() {
    if [ ! -f /tmp/firmware.img.tar.gz ]; then
        echo "No firmware file found!" >&2
        return 1
    fi

    # Backup config before upgrade
    echo "Backing up configuration..."
    BACKUP_DIR="/tmp/config-backup"
    mkdir -p "$BACKUP_DIR"

    # Backup /etc/config
    if [ -d "/etc/config" ]; then
        cp -a /etc/config "$BACKUP_DIR/"
    fi

    # Backup user account files (only shadow for root password, and sudoers)
    if [ -f "/etc/shadow" ]; then
        cp /etc/shadow "$BACKUP_DIR/"
    fi
    if [ -f "/etc/sudoers" ]; then
        cp /etc/sudoers "$BACKUP_DIR/"
    fi

    # Backup SSH keys
    if [ -d "/etc/dropbear" ]; then
        mkdir -p "$BACKUP_DIR/dropbear"
        cp -a /etc/dropbear/* "$BACKUP_DIR/dropbear/"
    fi

    # Backup marker files
    for marker in /etc/.gateway_configured /etc/.lora_configured /etc/.wifi_configured; do
        if [ -f "$marker" ]; then
            cp "$marker" "$BACKUP_DIR/"
        fi
    done

    echo "Extracting firmware..."
    tar -xzf /tmp/firmware.img.tar.gz -C /

    if [ $? -eq 0 ]; then
        # Restore config after upgrade
        echo "Restoring configuration..."
        if [ -d "$BACKUP_DIR/config" ]; then
            cp -a "$BACKUP_DIR/config/"* /etc/config/ 2>/dev/null
        fi

        # Restore user account files (merge with new system users)
        # Only restore root/admin password, keep new system users
        if [ -f "$BACKUP_DIR/shadow" ]; then
            # Extract root password hash from backup
            local root_hash=$(grep '^root:' "$BACKUP_DIR/shadow" 2>/dev/null | cut -d:':' -f2)
            if [ -n "$root_hash" ]; then
                sed -i "s|^root:[^:]*:|root:${root_hash}:|" /etc/shadow 2>/dev/null
            fi
            # Extract admin password hash from backup
            local admin_hash=$(grep '^admin:' "$BACKUP_DIR/shadow" 2>/dev/null | cut -d:':' -f2)
            if [ -n "$admin_hash" ]; then
                # Check if admin user exists in new shadow, update or add
                if grep -q '^admin:' /etc/shadow 2>/dev/null; then
                    sed -i "s|^admin:[^:]*:|admin:${admin_hash}:|" /etc/shadow 2>/dev/null
                else
                    # Add admin user entry from backup
                    grep '^admin:' "$BACKUP_DIR/shadow" >> /etc/shadow
                fi
            fi
        fi

        # Restore sudoers if backup exists
        if [ -f "$BACKUP_DIR/sudoers" ]; then
            cp "$BACKUP_DIR/sudoers" "/etc/sudoers"
        fi

        # Restore SSH keys
        if [ -d "$BACKUP_DIR/dropbear" ]; then
            mkdir -p /etc/dropbear
            cp -a "$BACKUP_DIR/dropbear/"* /etc/dropbear/ 2>/dev/null
        fi

        for marker in "$BACKUP_DIR"/.*_configured; do
            if [ -f "$marker" ]; then
                cp "$marker" /etc/
            fi
        done

        echo "Firmware upgraded successfully. Rebooting..."
        rm -f /tmp/firmware.img.tar.gz
        rm -rf "$BACKUP_DIR"
        sync
        reboot
        return 0
    else
        echo "Failed to extract firmware!" >&2
        rm -rf "$BACKUP_DIR"
        return 1
    fi
}

case "$action" in
    check)
        do_check "$@"
    ;;
    download)
        do_download "$@"
    ;;
    progress)
        do_progress
    ;;
    cancel)
        do_cancel
    ;;
    upgrade)
        do_upgrade
    ;;
    *)
        echo "usage: $0 {check|download|progress|cancel|upgrade}" >&2
        exit 1
    ;;
esac
