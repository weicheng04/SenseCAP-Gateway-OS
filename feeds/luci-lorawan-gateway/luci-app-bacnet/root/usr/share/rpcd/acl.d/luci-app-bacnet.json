{
	"luci-app-bacnet": {
		"description": "Grant access to BACnet Gateway configuration",
		"read": {
			"file": {
				"/etc/bacnet/profiles/*": ["list", "read"]
			},
			"ubus": {
				"uci": ["get"],
				"file": ["list", "read", "stat"]
			},
			"uci": ["bacnet"]
		},
		"write": {
			"file": {
				"/etc/bacnet/profiles/*": ["write", "remove"]
			},
			"ubus": {
				"uci": ["set"],
				"file": ["write", "remove"]
			},
			"uci": ["bacnet"]
		}
	}
}
