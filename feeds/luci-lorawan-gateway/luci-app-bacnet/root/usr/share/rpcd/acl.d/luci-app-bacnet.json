{
	"luci-app-bacnet": {
		"description": "Grant access to BACnet configuration",
		"read": {
			"ubus": {
				"uci": [
					"get"
				],
				"file": [
					"exec",
					"read"
				],
				"service": [
					"list"
				]
			},
			"uci": [
				"bacnet"
			],
			"file": {
				"/usr/bin/bacnet-env": [
					"exec"
				],
				"/usr/bin/bacwhois": [
					"exec"
				],
				"/usr/bin/bacrp": [
					"exec"
				],
				"/usr/bin/bacwp": [
					"exec"
				],
				"/etc/init.d/bacnet": [
					"exec"
				]
			}
		},
		"write": {
			"ubus": {
				"uci": [
					"set"
				],
				"file": [
					"exec",
					"write"
				]
			},
			"uci": [
				"bacnet"
			],
			"file": {
				"/etc/init.d/bacnet": [
					"exec"
				]
			}
		}
	}
}
